<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.yuchuri.snapcodejetbrains</id>
    <name>Snapcode</name>
    <vendor>yuchuri</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.SnapcodeBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.github.yuchuri.snapcodejetbrains.settings.SnapcodeSettingsState"/>
    </extensions>

    <actions>
        <action
            id="Snapcode.TakeSnapshot"
            class="com.github.yuchuri.snapcodejetbrains.actions.SnapcodeAction"
            text="Take Code Snapshot"
            description="Generate a beautiful image of the selected code">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
